{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "amegrad:amanar/knowledge/entry",
  "title": "Knowledge entry frontmatter",
  "description": "Governs the YAML frontmatter of every .md file written by kb save.",
  "type": "object",
  "required": ["id", "type", "title", "status"],
  "additionalProperties": false,
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1,
      "description": "Stable unique identifier (UUID recommended)."
    },
    "type": {
      "type": "string",
      "minLength": 1,
      "description": "Entry kind: fact, decision, reference, procedure, hypothesis, …"
    },
    "title": {
      "type": "string",
      "minLength": 1,
      "description": "Human-readable title; used for dedup and index linking."
    },
    "description": {
      "type": "string",
      "description": "One-sentence summary of what this entry captures."
    },
    "status": {
      "type": "string",
      "enum": ["active", "reference", "archive"],
      "description": "Lifecycle status."
    },
    "tags": {
      "type": "array",
      "items": {"type": "string"},
      "description": "Free-form labels for filtering and dedup."
    },
    "created": {
      "type": "string",
      "description": "ISO 8601 creation timestamp."
    },
    "last_verified": {
      "type": "string",
      "description": "ISO 8601 timestamp of last human or agent verification."
    },
    "ttl": {
      "type": "string",
      "pattern": "^\\d+(d|m|y)$",
      "description": "Time-to-live before entry is considered stale: e.g. 90d, 6m, 1y."
    },
    "confidence": {
      "type": "string",
      "enum": ["low", "medium", "high"],
      "description": "Confidence in the accuracy of this entry."
    },
    "sources": {
      "type": "array",
      "description": "Evidence trail for this entry.",
      "items": {
        "type": "object",
        "properties": {
          "url":      {"type": "string"},
          "sha256":   {"type": "string"},
          "ingested": {"type": "string"}
        }
      }
    },
    "provenance": {
      "type": "string",
      "enum": ["agent", "human", "distilled"],
      "description": "How this entry was produced."
    }
  }
}
