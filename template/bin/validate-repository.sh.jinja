#!/usr/bin/env bash
set -euo pipefail

root="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
cd "$root"

required_paths=(
  AGENTS.md
  README.md
  REPO-STANDARD.md
  docs/README.md
  docs/reference/project-charter.md
  data/README.md
  deliverables/README.md
)

for path in "${required_paths[@]}"; do
  if [[ ! -f "$path" ]]; then
    echo "missing required file: $path" >&2
    exit 1
  fi
done

git check-ignore -q --no-index data/local/validation-probe
git check-ignore -q --no-index artifacts/generated-output

repo_type='{{ repo_type }}'
# {% if repo_type in ["code", "library"] %}
package_name='{{ package_name }}'
[[ -f "pyproject.toml" ]]
[[ -f "src/$package_name/__init__.py" ]]
[[ -f "tests/test_package.py" ]]
python3 -c 'import pathlib, tomllib; tomllib.loads(pathlib.Path("pyproject.toml").read_text())'
python3 -m compileall -q "src/$package_name" tests
PYTHONPATH="$root/src" python3 -m unittest discover -s tests -v
# {% else %}
[[ ! -e pyproject.toml ]]
[[ ! -e src ]]
[[ ! -e tests ]]
# {% endif %}
git diff --check
printf 'legacy %s profile validation passed\n' "$repo_type"
