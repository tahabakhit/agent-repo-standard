{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://amanar.invalid/schema/workflow-1.0.0.json",
  "title": "Amanar portable workflow contract",
  "type": "object",
  "additionalProperties": false,
  "$defs": {
    "repositoryPath": {
      "type": "string",
      "minLength": 1,
      "pattern": "^(?!/)(?!\\.git(?:/|$))(?!\\.amanar/run(?:/|$))(?!.*(?:^|/)\\.{1,2}(?:/|$))(?!.*//)(?!\\s)(?!.*\\s$)[^\\u0000-\\u001F]+$"
    }
  },
  "required": ["schemaVersion", "id", "objective", "scope", "exclusions", "artifacts", "authority", "checks"],
  "properties": {
    "schemaVersion": {"const": "1.0.0"},
    "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
    "objective": {"type": "string", "minLength": 1},
    "scope": {
      "type": "array",
      "minItems": 1,
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/repositoryPath"}
    },
    "exclusions": {
      "type": "array",
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/repositoryPath"}
    },
    "artifacts": {
      "type": "array",
      "uniqueItems": true,
      "items": {"$ref": "#/$defs/repositoryPath"}
    },
    "authority": {
      "type": "object",
      "additionalProperties": false,
      "required": ["repositoryWrites", "liveEffects"],
      "properties": {
        "repositoryWrites": {"type": "boolean"},
        "liveEffects": {"type": "boolean"}
      }
    },
    "checks": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "additionalProperties": false,
        "allOf": [
          {
            "if": {"properties": {"minTests": {"minimum": 1}}, "required": ["minTests"]},
            "then": {"properties": {"testParser": {"not": {"const": "none"}}}}
          }
        ],
        "required": ["id", "command", "expectedExit", "outputContains", "timeoutSeconds", "minTests", "testParser", "liveEffect"],
        "properties": {
          "id": {"type": "string", "pattern": "^[a-z0-9]+(?:-[a-z0-9]+)*$"},
          "command": {"type": "string", "minLength": 1},
          "expectedExit": {"type": "integer", "minimum": 0, "maximum": 255},
          "outputContains": {"type": "array", "uniqueItems": true, "items": {"type": "string", "minLength": 1}},
          "timeoutSeconds": {"type": "number", "exclusiveMinimum": 0, "maximum": 3600},
          "minTests": {"type": "integer", "minimum": 0},
          "testParser": {"enum": ["none", "unittest", "pytest", "tap"]},
          "liveEffect": {"type": "boolean"}
        }
      }
    }
  }
}
